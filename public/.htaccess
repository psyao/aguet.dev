<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Redirect www to apex (canonical host)
    RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
    RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Handle X-XSRF-Token Header
    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # Redirect Trailing Slashes If Not A Folder...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Send Requests To Front Controller...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>

# Vite build assets are content-hashed (filename changes when content changes),
# so they can be cached forever. Scoped to /build/ to avoid touching mutable
# root files (favicon, robots.txt, sitemap.xml).
<IfModule mod_headers.c>
    <If "%{REQUEST_URI} =~ m#^/build/#">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </If>

    # Infomaniak's edge already injects its own HSTS header (low max-age, no
    # includeSubDomains) upstream of Apache; there's no panel setting for it.
    # "set" (not "add") overrides Apache's own header table, but whether that
    # wins over the edge's injection — vs. sending a duplicate header — is
    # unverified until deployed; check with curl after deploy. No preload:
    # that's a one-way door (removal takes browser vendors months to
    # propagate), not worth committing to speculatively.
    <If "%{HTTPS} == 'on'">
        Header set Strict-Transport-Security "max-age=63072000; includeSubDomains"
    </If>
</IfModule>
